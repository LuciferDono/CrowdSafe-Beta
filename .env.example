# ──────────────────────────────────────────────────────────────
# CrowdSafe-Beta — Environment Template
# Copy to .env and fill. Never commit .env.
# ──────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
FLASK_ENV=production
DEBUG=False
SECRET_KEY=__GENERATE_WITH__python_-c_import_secrets;print(secrets.token_urlsafe(64))__
JWT_SECRET_KEY=__GENERATE_WITH__python_-c_import_secrets;print(secrets.token_urlsafe(64))__
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=604800

# ── Default admin ─────────────────────────────────────────────
# If ADMIN_PASSWORD is unset, app generates random pwd on first boot
# and writes it to logs/FIRST_BOOT_CREDENTIALS.txt (chmod 600).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5001

# ── Database ──────────────────────────────────────────────────
# SQLite default. For production use PostgreSQL + TimescaleDB.
# DATABASE_URL=postgresql://user:pass@localhost:5432/crowdsafe

# ── AI / YOLO ─────────────────────────────────────────────────
GPU_ENABLED=True
MODEL_PATH=yolo11s.pt
YOLO_CONFIDENCE=0.25
YOLO_IOU=0.5
YOLO_IMGSZ=960

# ── Pose fusion (new) ─────────────────────────────────────────
POSE_ENABLED=True
POSE_MODEL=yolo11s-pose.pt

# ── Forecasting (new) ─────────────────────────────────────────
FORECAST_ENABLED=True
FORECAST_HORIZON_SECONDS=60

# ── HuggingFace (model downloads + inference) ─────────────────
HF_TOKEN=

# ── OpenRouter (LLM intelligence layer) ───────────────────────
OR_API_KEY=
OR_BASE_URL=https://openrouter.ai/api/v1
OR_MODEL_DEFAULT=google/gemini-2.5-flash
OR_MODEL_PREMIUM=anthropic/claude-sonnet-4.6
OR_MODEL_VISION=qwen/qwen3-vl-30b-a3b-instruct
OR_MODEL_NANO=openai/gpt-5-nano
OR_SITE_URL=https://github.com/LuciferDono/CrowdSafe-Beta
OR_APP_NAME=CrowdSafe-Beta

# ── Telegram alerts ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Rate limiting ─────────────────────────────────────────────
RATELIMIT_STORAGE_URI=memory://
# For prod use Redis: redis://localhost:6379
